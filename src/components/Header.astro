---
const currentPath = Astro.url.pathname;
const isActive = (path: string) => currentPath === path || (path !== '/' && currentPath.startsWith(path));

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/products', label: 'Products' },
  { href: '/subscription', label: 'Subscription', badge: 'New!' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
---

<header class="sticky top-0 z-50 w-full border-b border-gray-200 bg-white/95 backdrop-blur supports-[backdrop-filter]:bg-white/80">
  <div class="mx-auto max-w-7xl px-4 py-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 text-xl font-bold text-gray-900 tracking-tight hover:text-indigo-600 transition-colors">
        <img src="/favicon.png" alt="" class="w-8 h-8" />
        VDH
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center space-x-8" aria-label="Main navigation">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`text-sm font-medium transition-colors hover:text-indigo-600 ${
              isActive(link.href) ? 'text-indigo-600' : 'text-gray-600'
            }`}
          >
            {link.label}
            {link.badge && (
              <span class="ml-1 text-xs bg-green-500 text-white px-1.5 py-0.5 rounded-full font-semibold">
                {link.badge}
              </span>
            )}
          </a>
        ))}

        <!-- Cart Icon -->
        <a href="/cart" class="relative text-gray-600 hover:text-indigo-600 transition-colors" aria-label="Cart">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
          </svg>
          <span id="cart-count" class="hidden absolute -top-2 -right-2 bg-indigo-600 text-white text-xs font-bold rounded-full w-5 h-5 flex items-center justify-center">
            0
          </span>
        </a>
      </nav>

      <!-- Mobile: Cart + Hamburger -->
      <div class="flex items-center gap-4 md:hidden">
        <!-- Mobile Cart Icon -->
        <a href="/cart" class="relative text-gray-600 hover:text-indigo-600 transition-colors" aria-label="Cart">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
          </svg>
          <span id="cart-count-mobile" class="hidden absolute -top-2 -right-2 bg-indigo-600 text-white text-xs font-bold rounded-full w-5 h-5 flex items-center justify-center">
            0
          </span>
        </a>

        <!-- Hamburger -->
        <button
          id="mobile-menu-button"
          aria-label="Toggle menu"
          aria-expanded="false"
          class="w-10 h-10 text-gray-600 hover:text-indigo-600 transition flex items-center justify-center"
        >
          <span class="sr-only">Menu</span>
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Menu -->
    <nav
      id="mobile-menu"
      class="md:hidden overflow-hidden transition-all duration-200 max-h-0 opacity-0"
      aria-label="Mobile navigation"
    >
      <div class="pt-4 pb-2 space-y-1">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`block py-2 text-sm font-medium transition-colors hover:text-indigo-600 ${
              isActive(link.href) ? 'text-indigo-600' : 'text-gray-600'
            }`}
          >
            {link.label}
            {link.badge && (
              <span class="ml-1 text-xs bg-green-500 text-white px-1.5 py-0.5 rounded-full font-semibold">
                {link.badge}
              </span>
            )}
          </a>
        ))}
      </div>
    </nav>
  </div>
</header>

<script>
  const menuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');
  let isMenuOpen = false;

  menuButton?.addEventListener('click', () => {
    isMenuOpen = !isMenuOpen;
    menuButton.setAttribute('aria-expanded', isMenuOpen.toString());

    if (isMenuOpen) {
      mobileMenu?.classList.remove('max-h-0', 'opacity-0');
      mobileMenu?.classList.add('max-h-96', 'opacity-100');
    } else {
      mobileMenu?.classList.remove('max-h-96', 'opacity-100');
      mobileMenu?.classList.add('max-h-0', 'opacity-0');
    }
  });

  // Cart count update
  function updateCartCount() {
    const cartKey = 'vdh_cart';
    const stored = localStorage.getItem(cartKey);
    let cart = [];
    try {
      cart = stored ? JSON.parse(stored) : [];
      if (!Array.isArray(cart)) cart = [];
    } catch {
      localStorage.removeItem(cartKey);
      cart = [];
    }
    const count = cart.reduce((sum: number, item: {quantity: number}) => sum + item.quantity, 0);

    const countEl = document.getElementById('cart-count');
    const countElMobile = document.getElementById('cart-count-mobile');

    [countEl, countElMobile].forEach(el => {
      if (el) {
        if (count > 0) {
          el.textContent = count > 99 ? '99+' : count.toString();
          el.classList.remove('hidden');
        } else {
          el.classList.add('hidden');
        }
      }
    });
  }

  // Initial count
  updateCartCount();

  // Listen for cart updates
  window.addEventListener('cart-updated', updateCartCount);
</script>
