---
// Header component with navigation (NAV-01, NAV-05)
const { title = "Bostrich" } = Astro.props;

// Active page highlighting using server-side route detection (NAV-05, D-07, D-08, D-09)
const currentPath = Astro.url.pathname;
const isActive = (path: string) => currentPath === path;

// Navigation links (NAV-01, D-03)
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/products', label: 'Products' },
  { href: '/about', label: 'About' },
  { href: '/pricing', label: 'Pricing' },
  { href: '/contact', label: 'Contact' },
];
---

<header class="w-full border-b border-gray-200 bg-white">
  <div class="mx-auto max-w-7xl px-4 py-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between">
      <!-- Logo/title (preserved from Phase 1) -->
      <h1 class="text-xl font-bold text-gray-900 tracking-tight">
        {title}
      </h1>

      <!-- Desktop navigation (NAV-01, D-01, D-02) -->
      <nav aria-label="Main navigation">
        <ul class="hidden md:flex items-center space-x-8">
          {navLinks.map(link => (
            <li>
              <a
                href={link.href}
                class={`text-sm transition hover:text-indigo-600 ${
                  isActive(link.href) ? 'text-indigo-600 font-semibold' : 'text-gray-600'
                }`}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  </div>
</header>
