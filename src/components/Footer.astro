---
const currentYear = new Date().getFullYear();
---

<footer class="w-full border-t border-gray-200 bg-white/70">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="md:col-span-1">
        <a href="/" class="flex items-center gap-2 text-xl font-bold text-gray-900">
          <img src="/favicon.png" alt="" class="w-8 h-8" />
          Vertical Digital Holdings
        </a>
        <p class="mt-3 text-sm text-gray-500">
          Scalable solutions to take your business to the next level.
        </p>
      </div>

      <!-- Solutions -->
      <div>
        <h3 class="font-semibold text-gray-900 mb-4">Solutions</h3>
        <ul class="space-y-2">
          <li><a href="/products" class="text-sm text-gray-600 hover:text-indigo-600 transition">All Products</a></li>
          <li><a href="/subscription" class="text-sm text-gray-600 hover:text-indigo-600 transition">Subscription</a></li>
          <li><a href="/contact" class="text-sm text-gray-600 hover:text-indigo-600 transition">Enterprise</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="font-semibold text-gray-900 mb-4">Company</h3>
        <ul class="space-y-2">
          <li><a href="/about" class="text-sm text-gray-600 hover:text-indigo-600 transition">About</a></li>
          <li><a href="/subscription" class="text-sm text-gray-600 hover:text-indigo-600 transition">Subscription</a></li>
          <li><a href="/contact" class="text-sm text-gray-600 hover:text-indigo-600 transition">Contact</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h3 class="font-semibold text-gray-900 mb-4">Legal</h3>
        <ul class="space-y-2">
          <li><a href="/privacy" class="text-sm text-gray-600 hover:text-indigo-600 transition">Privacy Policy</a></li>
          <li><a href="/terms" class="text-sm text-gray-600 hover:text-indigo-600 transition">Terms of Service</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-8 pt-8 border-t border-gray-200">
      <p class="text-sm text-gray-500 text-center md:text-left">
        &copy; {currentYear} Vertical Digital Holdings. All rights reserved.
      </p>
    </div>
  </div>
</footer>
