---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Terms of Service — Bostrich" description="Terms and conditions for using Bostrich services.">
  <main class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
    <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-8">Terms of Service</h1>

    <div class="prose prose-gray max-w-none space-y-6 text-gray-600">
      <p class="text-sm text-gray-500">Last updated: April 2026</p>

      <h2 class="text-xl font-semibold text-gray-900 mt-8">Acceptance of Terms</h2>
      <p>
        By accessing and using this website, you accept and agree to be bound by the terms and provisions of this agreement.
      </p>

      <h2 class="text-xl font-semibold text-gray-900 mt-8">Use of Service</h2>
      <p>
        You agree to use this website only for lawful purposes and in a way that does not infringe the rights of, restrict, or inhibit anyone else's use of the website.
      </p>

      <h2 class="text-xl font-semibold text-gray-900 mt-8">Disclaimer</h2>
      <p>
        This website is provided for informational purposes only. While we strive for accuracy, we make no warranties about the completeness, reliability, or accuracy of this information.
      </p>

      <h2 class="text-xl font-semibold text-gray-900 mt-8">Limitation of Liability</h2>
      <p>
        In no event shall Bostrich be liable for any damages arising out of the use or inability to use this website or services.
      </p>

      <h2 class="text-xl font-semibold text-gray-900 mt-8">Contact</h2>
      <p>
        If you have questions about these Terms, please <a href="/contact" class="text-indigo-600 hover:text-indigo-700">contact us</a>.
      </p>
    </div>
  </main>
</Layout>
