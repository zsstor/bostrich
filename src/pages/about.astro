---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="About Bostrich — Democratizing Verticality and Agility"
  description="Our mission is to democratize verticality and accelerate agility for modern enterprises. Learn about our scalable infrastructure solutions."
>
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
    <h1 class="text-4xl md:text-6xl font-bold text-gray-900 mb-8">
      Democratizing Verticality and Accelerating Agility
    </h1>
    <p class="text-lg text-gray-600 max-w-3xl">
      At Bostrich, we believe every enterprise deserves scalable solutions to reach new heights. Our offboarding accelerators help teams transition smoothly to their next opportunity. Join thousands of organizations leveraging our infrastructure for growth and strategic exits.
    </p>
  </main>
</Layout>
