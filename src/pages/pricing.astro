---
import Layout from '../layouts/Layout.astro';
import { getAllProducts } from '../lib/data.ts';

const products = getAllProducts();
---
<Layout title="Pricing — Bostrich Enterprise Solutions" description="Tiered pricing for vertical mobility, offboarding accelerators, and growth infrastructure. Choose a plan that fits your enterprise needs.">
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
    <h1 class="text-4xl md:text-6xl font-bold text-gray-900 mb-16 text-center">Pricing</h1>

    {products.length > 0 ? (
      products.map((product) => (
      <section class="mb-16">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">{product.name}</h2>
        <p class="text-lg text-gray-600 mb-8">{product.tagline}</p>

        <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
          {Object.entries(product.pricing || {}).map(([tierName, price]) => (
            <div class={`border border-gray-200 rounded-lg p-6 flex flex-col ${tierName === 'business' ? 'border-2 border-indigo-600' : ''}`}>
              {tierName === 'business' && (
                <div class="bg-indigo-600 text-white text-xs font-semibold py-1 px-3 rounded-full mb-4 inline-block">Recommended</div>
              )}
              <h3 class="text-xl font-bold text-gray-900 mb-2 capitalize">{tierName}</h3>
              <p class="text-3xl font-extrabold text-gray-900 mb-4">{price}</p>
              <ul class="space-y-3 flex-1">
                {product.features.map((feature) => (
                  <li class="flex items-center text-gray-600">
                    <span class="text-indigo-600 mr-2">✓</span>{feature}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </section>
    ))
  ) : (
    <div class="max-w-2xl mx-auto text-center py-16">
      <p class="text-lg text-gray-600">Products are currently unavailable. Please check back later.</p>
    </div>
  )}
  </main>
</Layout>
