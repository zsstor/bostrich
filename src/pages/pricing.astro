---
import Layout from '../layouts/Layout.astro';
import { getAllProducts, formatPrice } from '../lib/data.ts';

const products = getAllProducts();
---

<Layout title="Pricing — Bostrich" description="Simple, transparent pricing. Choose the configuration that fits your organization.">
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
    <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4 text-center">Pricing</h1>
    <p class="text-xl text-gray-600 text-center mb-16 max-w-2xl mx-auto">
      Simple, transparent pricing. Each product offers multiple configurations to fit your needs.
    </p>

    <!-- Product Pricing Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
      {products.map((product) => (
        <div class="bg-white border border-gray-200 rounded-lg p-6 hover:shadow-lg transition-shadow">
          <h2 class="text-xl font-bold text-gray-900 mb-1">{product.name}</h2>
          <p class="text-indigo-600 font-medium text-sm mb-4">{product.tagline}</p>
          <p class="text-3xl font-bold text-gray-900 mb-4">
            From {formatPrice(product.price)}
          </p>
          <ul class="text-sm text-gray-600 space-y-2 mb-6">
            <li class="flex items-center">
              <span class="text-indigo-600 mr-2">•</span>
              {product.pricingTiers.starter}
            </li>
            <li class="flex items-center">
              <span class="text-indigo-600 mr-2">•</span>
              {product.pricingTiers.enterprise}
            </li>
          </ul>
          <a
            href={`/products/${product.slug}`}
            class="block w-full py-3 px-4 bg-gray-100 text-gray-900 font-medium text-center rounded-lg hover:bg-gray-200 transition-colors"
          >
            View Options
          </a>
        </div>
      ))}
    </div>

    <!-- Enterprise CTA -->
    <section class="bg-gray-900 rounded-2xl p-8 md:p-12 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">Need a custom solution?</h2>
      <p class="text-gray-400 mb-6 max-w-xl mx-auto">
        Our enterprise team can work with you to create a package tailored to your organization's specific requirements.
      </p>
      <a href="/contact" class="inline-block bg-white text-gray-900 font-semibold py-3 px-8 rounded-lg hover:bg-gray-100 transition-colors">
        Contact Enterprise Sales
      </a>
    </section>
  </main>
</Layout>
