---
import Layout from '../layouts/Layout.astro';
import { getAllProducts } from '../lib/data.ts';

const products = getAllProducts();

// Tier display config
const tierConfig = {
  starter: { label: 'Starter', price: '$49/mo' },
  growth: { label: 'Growth', price: '$149/mo' },
  business: { label: 'Business', price: '$349/mo', recommended: true },
  enterprise: { label: 'Enterprise', price: 'Custom' }
};
---

<Layout title="Pricing — Bostrich Enterprise Solutions" description="Tiered pricing for all your organizational needs. Choose a plan that scales with you.">
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
    <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4 text-center">Pricing</h1>
    <p class="text-xl text-gray-600 text-center mb-16 max-w-2xl mx-auto">
      Simple, transparent pricing that scales with your organization.
    </p>

    {products.map((product) => (
      <section class="mb-20">
        <div class="mb-8">
          <h2 class="text-2xl font-bold text-gray-900">{product.tagline}</h2>
          <p class="text-gray-500 mt-1">{product.name}</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
          {Object.entries(product.pricingTiers).map(([tierKey, value]) => {
            const tier = tierConfig[tierKey as keyof typeof tierConfig];
            return (
              <div class={`bg-white border rounded-lg p-6 flex flex-col ${tier.recommended ? 'border-2 border-indigo-600 relative' : 'border-gray-200'}`}>
                {tier.recommended && (
                  <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-indigo-600 text-white text-xs font-semibold py-1 px-3 rounded-full whitespace-nowrap">
                    Most Popular
                  </div>
                )}
                <h3 class="text-lg font-bold text-gray-900 mb-1">{tier.label}</h3>
                <p class="text-2xl font-bold text-indigo-600 mb-4">{tier.price}</p>
                <p class="text-gray-700 mb-6 flex-1">{value}</p>
                <a
                  href={tierKey === 'enterprise' ? '/contact' : '/products'}
                  class={`py-3 px-4 rounded-lg font-medium text-center transition-colors ${
                    tier.recommended
                      ? 'bg-indigo-600 text-white hover:bg-indigo-700'
                      : tierKey === 'enterprise'
                      ? 'bg-white text-indigo-600 border border-indigo-600 hover:bg-indigo-50'
                      : 'bg-gray-100 text-gray-900 hover:bg-gray-200'
                  }`}
                >
                  {tierKey === 'enterprise' ? 'Contact Sales' : 'Get Started'}
                </a>
              </div>
            );
          })}
        </div>
      </section>
    ))}

    <!-- Enterprise CTA -->
    <section class="bg-gray-900 rounded-2xl p-8 md:p-12 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">Need a custom solution?</h2>
      <p class="text-gray-400 mb-6 max-w-xl mx-auto">
        Our enterprise team can work with you to create a package tailored to your organization's specific requirements.
      </p>
      <a href="/contact" class="inline-block bg-white text-gray-900 font-semibold py-3 px-8 rounded-lg hover:bg-gray-100 transition-colors">
        Contact Enterprise Sales
      </a>
    </section>
  </main>
</Layout>
