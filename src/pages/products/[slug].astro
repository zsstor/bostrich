---
import Layout from '../../layouts/Layout.astro';
import { getAllProducts, getProductBySlug } from '../../lib/data.ts';

// Generate static paths for all 7 products
export async function getStaticPaths() {
  const products = getAllProducts();
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

// Props interface for dynamic route
interface Props {
  product: {
    id: string;
    name: string;
    slug: string;
    tagline: string;
    description: string;
    features: string[];
    pricing?: {
      free?: string;
      basic?: string;
      business?: string;
      enterprise?: string;
    };
    imageUrl?: string;
  };
}

// Destructure product from props
const { product } = Astro.props;

// Handle 404 for invalid slug
if (!product) {
  return Astro.redirect('/404');
}

// Dynamic product page: hero section, features list, pricing tiers
// Requirements: PROD-03, PROD-04, PROD-05, PROD-06, PROD-07, PROD-08
---

<Layout
  title={`${product.name} — Bostrich Enterprise Solutions`}
  description={`${product.tagline}. ${product.description}`}
>
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
    <!-- Hero Section -->
    <section class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center mb-16 md:mb-24">
      <div class="mb-6 lg:mb-0">
        {product.imageUrl && (
          <img
            src={product.imageUrl}
            alt={`${product.name} - ${product.tagline}`}
            width="800"
            height="600"
            loading="lazy"
            class="w-full h-96 object-cover rounded-lg"
          />
        )}
      </div>
      <div>
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
          {product.name}
        </h1>
        <p class="text-2xl text-indigo-600 font-medium mb-6">
          {product.tagline}
        </p>
        <p class="text-lg text-gray-600 leading-relaxed mb-8">
          {product.description}
        </p>
        <a
          href="/pricing"
          class="inline-block bg-indigo-600 text-white px-8 py-3 rounded-lg font-medium hover:bg-indigo-700"
        >
          Get Started
        </a>
      </div>
    </section>

    <!-- Features Section -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-12 text-center">
        Features
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
        {product.features.map((feature) => (
          <div class="flex items-start">
            <span class="text-indigo-600 mr-3 text-2xl font-bold">✓</span>
            <p class="text-lg text-gray-700 font-medium">{feature}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Pricing Section -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-12 text-center">
        Pricing
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {Object.entries(product.pricing || {}).map(([tierName, price]) => (
          <div class={`border border-gray-200 rounded-lg p-6 flex flex-col ${
            tierName === 'business' ? 'border-2 border-indigo-600' : ''
          }`}>
            {tierName === 'business' && (
              <div class="bg-indigo-600 text-white text-xs font-semibold py-1 px-3 rounded-full mb-4 inline-block">
                Recommended
              </div>
            )}
            <h3 class="text-xl font-bold text-gray-900 mb-2 capitalize">
              {tierName}
            </h3>
            <p class="text-3xl font-extrabold text-gray-900 mb-4">
              {price}
            </p>
            <ul class="space-y-3 flex-1">
              {product.features.map((feature) => (
                <li class="flex items-center text-gray-600">
                  <span class="text-indigo-600 mr-2">✓</span>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>
            <a
              href="/contact"
              class={`w-full py-2 rounded-lg font-medium text-center ${
                tierName === 'enterprise'
                  ? 'bg-white text-indigo-600 border border-indigo-600 hover:bg-indigo-50'
                  : 'bg-indigo-600 text-white hover:bg-indigo-700'
              }`}
            >
              {tierName === 'enterprise' ? 'Contact Sales' : 'Get Started'}
            </a>
          </div>
        ))}
      </div>
    </section>
  </main>
</Layout>
