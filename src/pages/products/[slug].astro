---
import Layout from '../../layouts/Layout.astro';
import { getAllProducts, getProductBySlug, formatPrice } from '../../lib/data.ts';

export async function getStaticPaths() {
  const products = getAllProducts();
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;

if (!product) {
  return Astro.redirect('/404');
}
---

<Layout
  title={`${product.name} — Bostrich`}
  description={`${product.name}. ${formatPrice(product.price)}. Free shipping on orders over $500.`}
>
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-16">
    <!-- Breadcrumb -->
    <nav class="mb-8">
      <ol class="flex items-center space-x-2 text-sm text-gray-500">
        <li><a href="/" class="hover:text-indigo-600">Home</a></li>
        <li>/</li>
        <li><a href="/products" class="hover:text-indigo-600">Products</a></li>
        <li>/</li>
        <li class="text-gray-900">{product.name}</li>
      </ol>
    </nav>

    <!-- Product Detail -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mb-16">
      <!-- Image -->
      <div>
        {product.imageUrl && (
          <img
            src={product.imageUrl}
            alt={product.name}
            class="w-full rounded-lg"
            fetchpriority="high"
          />
        )}
      </div>

      <!-- Info -->
      <div>
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          {product.name}
        </h1>
        <p class="text-3xl font-bold text-gray-900 mb-6">
          {formatPrice(product.price)}
        </p>
        <p class="text-gray-600 mb-8">
          {product.description}
        </p>

        <!-- Quantity & Add to Cart -->
        <div class="flex items-center gap-4 mb-8">
          <div class="flex items-center border border-gray-300 rounded">
            <button id="qty-minus" class="px-4 py-2 text-gray-600 hover:bg-gray-100 transition-colors">−</button>
            <input
              type="number"
              id="qty-input"
              value="1"
              min="1"
              max="99"
              class="w-16 text-center border-x border-gray-300 py-2 focus:outline-none"
            />
            <button id="qty-plus" class="px-4 py-2 text-gray-600 hover:bg-gray-100 transition-colors">+</button>
          </div>
          <button
            id="add-to-cart-btn"
            class="flex-1 bg-indigo-600 text-white font-semibold py-3 px-6 rounded hover:bg-indigo-700 transition-colors"
            data-product-id={product.id}
          >
            Add to Cart
          </button>
        </div>

        <!-- Shipping Info -->
        <div class="border-t border-gray-200 pt-6 space-y-3 text-sm text-gray-600">
          <div class="flex items-center">
            <svg class="w-5 h-5 mr-2 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            In Stock — Ships within 2-3 business days
          </div>
          <div class="flex items-center">
            <svg class="w-5 h-5 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
            </svg>
            Free returns within 30 days
          </div>
        </div>
      </div>
    </div>

    <!-- Specifications -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Specifications</h2>
      <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
        <table class="w-full">
          <tbody class="divide-y divide-gray-200">
            {product.specs.height && (
              <tr>
                <td class="px-6 py-4 text-sm font-medium text-gray-500 bg-gray-50 w-1/3">Height</td>
                <td class="px-6 py-4 text-sm text-gray-900">{product.specs.height}</td>
              </tr>
            )}
            {product.specs.length && (
              <tr>
                <td class="px-6 py-4 text-sm font-medium text-gray-500 bg-gray-50 w-1/3">Length</td>
                <td class="px-6 py-4 text-sm text-gray-900">{product.specs.length}</td>
              </tr>
            )}
            {product.specs.width && (
              <tr>
                <td class="px-6 py-4 text-sm font-medium text-gray-500 bg-gray-50 w-1/3">Width</td>
                <td class="px-6 py-4 text-sm text-gray-900">{product.specs.width}</td>
              </tr>
            )}
            <tr>
              <td class="px-6 py-4 text-sm font-medium text-gray-500 bg-gray-50 w-1/3">Material</td>
              <td class="px-6 py-4 text-sm text-gray-900">{product.specs.material}</td>
            </tr>
            <tr>
              <td class="px-6 py-4 text-sm font-medium text-gray-500 bg-gray-50 w-1/3">Weight</td>
              <td class="px-6 py-4 text-sm text-gray-900">{product.specs.weight}</td>
            </tr>
            {product.specs.capacity && (
              <tr>
                <td class="px-6 py-4 text-sm font-medium text-gray-500 bg-gray-50 w-1/3">Capacity</td>
                <td class="px-6 py-4 text-sm text-gray-900">{product.specs.capacity}</td>
              </tr>
            )}
          </tbody>
        </table>
      </div>
    </section>

    <!-- See Pricing Tiers CTA -->
    <section class="bg-gray-50 border border-gray-200 rounded-lg p-8 text-center">
      <h2 class="text-xl font-bold text-gray-900 mb-2">Need a different configuration?</h2>
      <p class="text-gray-600 mb-4">We offer multiple tiers to fit your organization's needs.</p>
      <a href="/pricing" class="inline-block text-indigo-600 font-semibold hover:text-indigo-700 transition-colors">
        View Pricing Options →
      </a>
    </section>
  </main>
</Layout>

<script define:vars={{ productId: product.id }}>
  const minusBtn = document.getElementById('qty-minus');
  const plusBtn = document.getElementById('qty-plus');
  const qtyInput = document.getElementById('qty-input');
  const addToCartBtn = document.getElementById('add-to-cart-btn');

  minusBtn?.addEventListener('click', () => {
    const current = parseInt(qtyInput.value) || 1;
    if (current > 1) qtyInput.value = current - 1;
  });

  plusBtn?.addEventListener('click', () => {
    const current = parseInt(qtyInput.value) || 1;
    if (current < 99) qtyInput.value = current + 1;
  });

  addToCartBtn?.addEventListener('click', () => {
    const quantity = parseInt(qtyInput.value) || 1;

    const cartKey = 'bostrich_cart';
    const stored = localStorage.getItem(cartKey);
    const cart = stored ? JSON.parse(stored) : [];

    const existing = cart.find(item => item.productId === productId);
    if (existing) {
      existing.quantity += quantity;
    } else {
      cart.push({ productId, quantity });
    }

    localStorage.setItem(cartKey, JSON.stringify(cart));
    window.dispatchEvent(new CustomEvent('cart-updated'));

    // Visual feedback
    const originalText = addToCartBtn.textContent;
    addToCartBtn.textContent = 'Added to Cart!';
    addToCartBtn.classList.remove('bg-indigo-600', 'hover:bg-indigo-700');
    addToCartBtn.classList.add('bg-green-600');

    setTimeout(() => {
      addToCartBtn.textContent = originalText;
      addToCartBtn.classList.remove('bg-green-600');
      addToCartBtn.classList.add('bg-indigo-600', 'hover:bg-indigo-700');
    }, 1500);
  });
</script>
