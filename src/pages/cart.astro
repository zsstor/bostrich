---
import Layout from '../layouts/Layout.astro';
import { getAllProducts, formatPrice } from '../lib/data.ts';

const products = getAllProducts();
const productsJson = JSON.stringify(products);
const checkoutUrl = 'https://fosterparrotsandthenewenglandexoticwildlifesanctuary-bloom.kindful.com/';
---

<Layout title="Cart — Bostrich" description="Review your cart and proceed to checkout." noindex>
  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
    <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-8">Your Cart</h1>

    <!-- Empty State -->
    <div id="empty-cart" class="hidden text-center py-16">
      <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
      </svg>
      <h2 class="text-xl font-semibold text-gray-900 mb-2">Your cart is empty</h2>
      <p class="text-gray-600 mb-6">Looks like you haven't added any products yet.</p>
      <a href="/products" class="inline-block bg-indigo-600 text-white font-semibold py-3 px-6 rounded-lg hover:bg-indigo-700 transition-colors">
        Browse Products
      </a>
    </div>

    <!-- Cart Items -->
    <div id="cart-content" class="hidden">
      <div id="cart-items" class="divide-y divide-gray-200 border-t border-b border-gray-200 mb-8">
        <!-- Items rendered by JS -->
      </div>

      <!-- Cart Summary -->
      <div class="flex flex-col items-end">
        <div class="w-full md:w-80 space-y-4">
          <div class="flex justify-between text-lg">
            <span class="text-gray-600">Subtotal</span>
            <span id="cart-subtotal" class="font-semibold text-gray-900">$0</span>
          </div>
          <div class="flex justify-between text-sm text-gray-500">
            <span>Shipping</span>
            <span id="shipping-text">Calculated at checkout</span>
          </div>
          <div class="border-t border-gray-200 pt-4 flex justify-between text-xl">
            <span class="font-semibold text-gray-900">Total</span>
            <span id="cart-total" class="font-bold text-gray-900">$0</span>
          </div>
          <button
            id="checkout-btn"
            class="w-full bg-indigo-600 text-white font-semibold py-4 px-6 rounded-lg hover:bg-indigo-700 transition-colors text-lg"
          >
            Proceed to Checkout
          </button>
          <p class="text-xs text-gray-500 text-center">
            Secure checkout. Free shipping on orders over $500.
          </p>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script define:vars={{ productsJson, checkoutUrl }}>
  const products = JSON.parse(productsJson);
  const cartKey = 'bostrich_cart';

  function formatPrice(price) {
    return '$' + price.toLocaleString();
  }

  function getProduct(productId) {
    return products.find(p => p.id === productId);
  }

  function renderCart() {
    const stored = localStorage.getItem(cartKey);
    const cart = stored ? JSON.parse(stored) : [];

    const emptyEl = document.getElementById('empty-cart');
    const contentEl = document.getElementById('cart-content');
    const itemsEl = document.getElementById('cart-items');

    if (cart.length === 0) {
      emptyEl.classList.remove('hidden');
      contentEl.classList.add('hidden');
      return;
    }

    emptyEl.classList.add('hidden');
    contentEl.classList.remove('hidden');

    let subtotal = 0;
    let html = '';

    cart.forEach(item => {
      const product = getProduct(item.productId);
      if (!product) return;

      const lineTotal = product.price * item.quantity;
      subtotal += lineTotal;

      html += `
        <div class="py-6 flex items-center gap-6" data-product-id="${item.productId}">
          ${product.imageUrl ? `<img src="${product.imageUrl}" alt="${product.name}" class="w-20 h-20 object-cover rounded" />` : ''}
          <div class="flex-1">
            <h3 class="font-semibold text-gray-900">${product.name}</h3>
            <p class="text-sm text-gray-500">${formatPrice(product.price)} each</p>
          </div>
          <div class="flex items-center gap-4">
            <div class="flex items-center border border-gray-300 rounded">
              <button class="qty-btn px-3 py-1 text-gray-600 hover:bg-gray-100" data-action="minus" data-product-id="${item.productId}">−</button>
              <span class="px-3 py-1 text-center min-w-[40px]">${item.quantity}</span>
              <button class="qty-btn px-3 py-1 text-gray-600 hover:bg-gray-100" data-action="plus" data-product-id="${item.productId}">+</button>
            </div>
            <div class="w-24 text-right font-semibold text-gray-900">
              ${formatPrice(lineTotal)}
            </div>
            <button class="remove-btn text-gray-400 hover:text-red-600 transition-colors" data-product-id="${item.productId}">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>
        </div>
      `;
    });

    itemsEl.innerHTML = html;

    const shipping = subtotal >= 500 ? 0 : 49;
    const total = subtotal + shipping;

    document.getElementById('cart-subtotal').textContent = formatPrice(subtotal);
    document.getElementById('shipping-text').textContent = shipping === 0 ? 'Free' : formatPrice(shipping);
    document.getElementById('cart-total').textContent = formatPrice(total);

    // Attach event listeners
    document.querySelectorAll('.qty-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const target = e.currentTarget;
        const productId = target.dataset.productId;
        const action = target.dataset.action;

        const stored = localStorage.getItem(cartKey);
        const cart = stored ? JSON.parse(stored) : [];
        const item = cart.find(i => i.productId === productId);

        if (item) {
          if (action === 'plus') {
            item.quantity += 1;
          } else if (action === 'minus') {
            item.quantity -= 1;
            if (item.quantity <= 0) {
              cart.splice(cart.indexOf(item), 1);
            }
          }
          localStorage.setItem(cartKey, JSON.stringify(cart));
          window.dispatchEvent(new CustomEvent('cart-updated'));
          renderCart();
        }
      });
    });

    document.querySelectorAll('.remove-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const target = e.currentTarget;
        const productId = target.dataset.productId;

        const stored = localStorage.getItem(cartKey);
        const cart = stored ? JSON.parse(stored) : [];
        const filtered = cart.filter(i => i.productId !== productId);

        localStorage.setItem(cartKey, JSON.stringify(filtered));
        window.dispatchEvent(new CustomEvent('cart-updated'));
        renderCart();
      });
    });
  }

  // Initial render
  renderCart();

  // Listen for cart updates
  window.addEventListener('cart-updated', renderCart);

  // Checkout button - redirect to parrot sanctuary
  document.getElementById('checkout-btn')?.addEventListener('click', () => {
    window.location.href = checkoutUrl;
  });
</script>
