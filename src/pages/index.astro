---
import Layout from '../layouts/Layout.astro';
import { getAllProducts } from '../lib/data.ts';

const featuredProducts = getAllProducts().slice(0, 4);
---

<Layout title="Bostrich — Scalable Solutions to Take Your Business to the Next Level" description="Industry-leading vertical mobility solutions and offboarding accelerators for modern enterprises. Take your business to new heights with Bostrich.">
  <main>
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
      <h1 class="text-4xl md:text-6xl font-extrabold text-gray-900 text-center mb-4">Scalable Solutions to Take Your Business to the Next Level</h1>
      <p class="text-lg text-gray-600 text-center mb-8 max-w-2xl mx-auto">Industry-leading vertical mobility and offboarding accelerators for modern enterprises</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/products" class="inline-block bg-indigo-600 text-white font-bold py-3 px-6 rounded-lg hover:bg-indigo-700 transition-colors">Get Started</a>
        <a href="/about" class="inline-block text-indigo-600 font-semibold py-3 px-6 hover:text-indigo-700 transition-colors">Learn More</a>
      </div>
    </section>
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
      <h2 class="text-3xl font-bold text-gray-900 text-center mb-12">Featured Products</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {featuredProducts.map(product => (
          <div class="bg-white border border-gray-200 rounded-lg p-6 hover:shadow-md transition-shadow">
            <h3 class="text-xl font-semibold text-gray-900 mb-2">{product.name}</h3>
            <p class="text-indigo-600 font-medium mb-3">{product.tagline}</p>
            <p class="text-gray-600">{product.description}</p>
          </div>
        ))}
      </div>
    </section>
  </main>
</Layout>
